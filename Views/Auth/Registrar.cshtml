@model frontendnet.Models.Registro
@{
    ViewData["Title"] = "Crear nueva cuenta";
}

<form asp-action="Registrar" method="post">
    <div class="card mx-auto shadow-sm" style="max-width: 500px;">
        <div class="card-body">
            <h1 class="h4 text-center mb-4">@ViewData["Title"]</h1>
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Nombre" class="form-control" placeholder="Nombre completo">
                <label asp-for="Nombre" class="form-label"></label>
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email">
                <label asp-for="Email" class="form-label"></label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Password" class="form-control" placeholder="Password">
                <label asp-for="Password" class="form-label"></label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Registrarse</button>
            </div>
            
            <p class="card-text small text-center mt-3">
                ¿Ya tienes cuenta? <a asp-action="Index" class="link-primary text-decoration-none">Inicia sesión aquí</a>
            </p>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}