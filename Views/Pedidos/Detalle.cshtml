@model DetallePedido
@{
    ViewData["Title"] = "Detalle del Pedido";
    bool esAdmin = ViewBag.SoloAdmin == true;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Volver a pedidos</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger shadow-sm">@TempData["ErrorMessage"]</div>
}

<div class="row">
    <div class="col-md-@(esAdmin ? "8" : "12")">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Pedido #@Model.PedidoId</h5>
                <span class="badge text-bg-secondary text-uppercase fs-6">@Model.Estado</span>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (Model.Productos != null)
                    {
                        foreach (var prod in Model.Productos)
                        {
                            <li class="list-group-item d-flex align-items-center p-3">
                                <img src="@((prod.ArchivoId == null) ? "https://dummyimage.com/100x100/cccccc/000000.png&text=Articulo" : Url.Action("Imagen", "Archivos", new { id = prod.ArchivoId }))"
                                     class="rounded me-3 shadow-sm" style="width: 60px; height: 80px; object-fit: cover;">
                                     
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold">@prod.Titulo</h6>
                                    <small class="text-muted">Cantidad: @prod.Cantidad</small>
                                </div>
                                <div class="text-end fw-bold">
                                    $@prod.PrecioVenta <br />
                                    <small class="text-muted fw-normal">Subtotal: $@(prod.Cantidad * Convert.ToDecimal(prod.PrecioVenta ?? "0"))</small>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
            <div class="card-footer text-end bg-white p-3">
                <h4 class="mb-0">Total pagado: <span class="text-success">$@Model.Total</span></h4>
            </div>
        </div>
    </div>

    @if (esAdmin)
    {
        <div class="col-md-4">
            <div class="card shadow-sm border-primary">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-gear-fill"></i> Panel de Control
                </div>
                <div class="card-body">
                    <p class="small text-muted">Actualizar el estado del pedido. Las transiciones deben seguir el orden lógico.</p>
                    
                    <form asp-action="ActualizarEstado" method="post">
                        <input type="hidden" name="id" value="@Model.PedidoId" />
                        <div class="mb-3">
                            <label class="form-label fw-bold">Cambiar estado a:</label>
                            <select name="nuevoEstado" class="form-select">
                                <option value="pendiente" selected="@(Model.Estado == "pendiente")">Pendiente</option>
                                <option value="aprobado" selected="@(Model.Estado == "aprobado")">Aprobado</option>
                                <option value="enviado" selected="@(Model.Estado == "enviado")">Enviado</option>
                                <option value="entregado" selected="@(Model.Estado == "entregado")">Entregado</option>
                                <option value="cancelado" selected="@(Model.Estado == "cancelado")">Cancelado</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold">Aplicar Cambios</button>
                    </form>
                    
                    <hr />
                    <p class="small text-muted mb-0">Última actualización: <br/> @(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</p>
                </div>
            </div>
        </div>
    }
</div>