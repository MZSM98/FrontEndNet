@model IEnumerable<frontendnet.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos Recibidos";
    bool soloAdmin = ViewBag.SoloAdmin ?? false;
}

<div class="container my-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info" role="alert">
            No se encontraron pedidos registrados.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Id)</th>
                        @if (soloAdmin)
                        {
                            <th>Cliente</th>
                        }
                        <th>@Html.DisplayNameFor(model => model.Total)</th>
                        <th>@Html.DisplayNameFor(model => model.Estado)</th>
                        <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.Id</td>
                            @if (soloAdmin)
                            {
                                <td>@item.Cliente?.Email</td>
                            }
                            <td class="text-success fw-bold">@Html.DisplayFor(modelItem => item.Total)</td>
                            <td>
                                <span class="badge @(item.Estado == "entregado" ? "bg-success" : 
                                                     item.Estado == "cancelado" ? "bg-danger" : 
                                                     item.Estado == "pendiente" ? "bg-warning text-dark" : "bg-info")">
                                    @item.Estado
                                </span>
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                    Ver Detalles
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>