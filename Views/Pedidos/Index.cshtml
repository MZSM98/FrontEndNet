@model IEnumerable<Pedido>
@{
    ViewData["Title"] = "Pedidos";
    bool esAdmin = ViewBag.SoloAdmin == true;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@(esAdmin ? "Gestión de Pedidos (Administrador)" : "Mis Pedidos")</h2>
</div>
@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger shadow-sm mb-4">@ViewBag.ErrorMessage</div>
}
@if (Model == null || !Model.Any())
{
    <div class="alert alert-info shadow-sm">
        No se encontraron pedidos registrados.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3"># Pedido</th>
                        <th>Fecha</th>
                        @if (esAdmin) { <th>Cliente</th> }
                        <th>Total</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@item.Id</td>
                            <td>@(item.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                            @if (esAdmin) { 
                                <td>
                                    @item.Cliente?.Nombre <br/>
                                    <small class="text-muted">@item.Cliente?.Email</small>
                                </td> 
                            }
                            <td>$@item.Total</td>
                            <td>
                                @{
                                    var badgeClass = item.Estado switch {
                                        "pendiente" => "text-bg-warning",
                                        "aprobado" => "text-bg-primary",
                                        "enviado" => "text-bg-info",
                                        "entregado" => "text-bg-success",
                                        "cancelado" => "text-bg-danger",
                                        _ => "text-bg-secondary"
                                    };
                                }
                                <span class="badge rounded-pill @badgeClass text-uppercase">@item.Estado</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Ver Detalle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}